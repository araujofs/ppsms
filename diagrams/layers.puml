@startuml LayersDiagram

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam packageStyle rectangle
skinparam linetype ortho

title Camadas - versão simplificada com padrões

' ============================================================
' REFERÊNCIAS EXTERNAS
' ============================================================

class User <<domain>>
class SubmissionEvent <<domain>>
class Area <<domain>>
class Article <<domain>>
class Review <<domain>>
class ReviewerProfile <<domain>>

exception UnauthorizedOperationException

class Category <<enum>>
class Verdict <<enum>>

class ReviewWorkflowContext <<patterns>>
interface ReviewWorkflowFactory <<patterns>>
class EventPublisher <<patterns>>


' ============================================================
' REPOSITÓRIOS
' ============================================================

package "Repositórios em Memória" as RepoPkg {

  interface ResettableRepository {
    + deleteAll(): void
  }

  interface UserRepository {
    + findAll(): List<User>
    + findById(id: Integer): Optional<User>
    + findByEmail(email: String): Optional<User>
    + save(user: User): User
  }

  interface SubmissionEventRepository {
    + saveCurrent(event: SubmissionEvent): void
    + findCurrent(): Optional<SubmissionEvent>
  }

  interface AreaRepository {
    + findAll(): List<Area>
    + findById(id: Integer): Optional<Area>
    + findByIds(ids: List<Integer>): List<Area>
    + save(area: Area): Area
    + deleteAll(): void
  }

  interface ReviewerRepository {
    + findAll(): List<ReviewerProfile>
    + findByUser(user: User): Optional<ReviewerProfile>
    + save(reviewer: ReviewerProfile): ReviewerProfile
    + deleteAll(): void
  }

  interface ArticleRepository {
    + findAll(): List<Article>
    + findByAuthor(author: User): List<Article>
    + findPending(): List<Article>
    + findFinished(): List<Article>
    + save(article: Article): Article
    + deleteAll(): void
  }

  interface ReviewRepository {
    + findAll(): List<Review>
    + findByArticle(article: Article): List<Review>
    + findByReviewer(reviewer: ReviewerProfile): List<Review>
    + save(review: Review): Review
    + saveAll(reviews: List<Review>): void
    + deleteAll(): void
  }

  class InMemoryUserRepository {
    - users: List<User>
    - nextId: int
    + findAll(): List<User>
    + findById(id: Integer): Optional<User>
    + findByEmail(email: String): Optional<User>
    + save(user: User): User
  }

  class InMemorySubmissionEventRepository {
    - currentEvent: SubmissionEvent
    + saveCurrent(event: SubmissionEvent): void
    + findCurrent(): Optional<SubmissionEvent>
  }

  class InMemoryAreaRepository {
    - areas: List<Area>
    - nextId: int
    + findAll(): List<Area>
    + findById(id: Integer): Optional<Area>
    + findByIds(ids: List<Integer>): List<Area>
    + save(area: Area): Area
    + deleteAll(): void
  }

  class InMemoryReviewerRepository {
    - reviewers: List<ReviewerProfile>
    - nextId: int
    + findAll(): List<ReviewerProfile>
    + findByUser(user: User): Optional<ReviewerProfile>
    + save(reviewer: ReviewerProfile): ReviewerProfile
    + deleteAll(): void
  }

  class InMemoryArticleRepository {
    - articles: List<Article>
    - nextId: int
    + findAll(): List<Article>
    + findByAuthor(author: User): List<Article>
    + findPending(): List<Article>
    + findFinished(): List<Article>
    + save(article: Article): Article
    + deleteAll(): void
  }

  class InMemoryReviewRepository {
    - reviews: List<Review>
    - nextId: int
    + findAll(): List<Review>
    + findByArticle(article: Article): List<Review>
    + findByReviewer(reviewer: ReviewerProfile): List<Review>
    + save(review: Review): Review
    + saveAll(reviews: List<Review>): void
    + deleteAll(): void
  }
}

UserRepository <|.. InMemoryUserRepository
SubmissionEventRepository <|.. InMemorySubmissionEventRepository
AreaRepository <|.. InMemoryAreaRepository
ReviewerRepository <|.. InMemoryReviewerRepository
ArticleRepository <|.. InMemoryArticleRepository
ReviewRepository <|.. InMemoryReviewRepository

ResettableRepository <|-- AreaRepository
ResettableRepository <|-- ReviewerRepository
ResettableRepository <|-- ArticleRepository
ResettableRepository <|-- ReviewRepository

UserRepository ..> User
SubmissionEventRepository ..> SubmissionEvent
AreaRepository ..> Area
ReviewerRepository ..> ReviewerProfile
ReviewerRepository ..> User
ArticleRepository ..> Article
ArticleRepository ..> User
ReviewRepository ..> Review
ReviewRepository ..> Article
ReviewRepository ..> ReviewerProfile

InMemoryUserRepository o-- User
InMemorySubmissionEventRepository o-- SubmissionEvent
InMemoryAreaRepository o-- Area
InMemoryReviewerRepository o-- ReviewerProfile
InMemoryArticleRepository o-- Article
InMemoryReviewRepository o-- Review


' ============================================================
' SERVICES
' ============================================================

package "Services" as ServicePkg {

  class AccountService {
    - userRepository: UserRepository
    - currentUser: User
    + registerResearcher(data: RegisterUserData): User
    + authenticate(email: String, password: String): User
    + getCurrentUser(): User
    + logout(): void
    + isCurrentUserCoordinator(): boolean
  }

  class EventService {
    - eventRepository: SubmissionEventRepository
    - eventScopedRepositories: List<ResettableRepository>
    - workflowContext: ReviewWorkflowContext
    + startEvent(data: StartEventData): SubmissionEvent
    + getCurrentEvent(): SubmissionEvent
    + getDashboard(): CoordinatorDashboard
    - selectFactory(reviewersPerArticle: int): ReviewWorkflowFactory
  }

  class CommitteeService {
    - userRepository: UserRepository
    - areaRepository: AreaRepository
    - reviewerRepository: ReviewerRepository
    + registerArea(name: String): Area
    + listAreas(): List<Area>
    + findAreasByIds(ids: List<Integer>): List<Area>
    + inviteResearcher(userId: Integer): ReviewerProfile
    + defineExpertiseAreas(user: User, areaIds: List<Integer>): ReviewerProfile
    + needsExpertiseAreas(user: User): boolean
    + findReviewerByUser(user: User): ReviewerProfile
    + listReviewers(): List<ReviewerProfile>
  }

  class ArticleReviewService {
    - articleRepository: ArticleRepository
    - reviewRepository: ReviewRepository
    - committeeService: CommitteeService
    - eventService: EventService
    - accountService: AccountService
    - workflowContext: ReviewWorkflowContext
    - eventPublisher: EventPublisher
    + submitArticle(data: SubmitArticleData): Article
    + listMyArticles(): List<Article>
    + listArticlesForReview(reviewer: ReviewerProfile): List<ArticleForReviewDTO>
    + listAssignedReviews(reviewer: ReviewerProfile): List<Review>
    + submitReview(data: ReviewData): void
  }

  class DistributionService {
    - articleRepository: ArticleRepository
    - reviewerRepository: ReviewerRepository
    - reviewRepository: ReviewRepository
    - workflowContext: ReviewWorkflowContext
    - eventPublisher: EventPublisher
    + distributeArticles(): void
  }

  class DataSeeder {
    - accountService: AccountService
    - eventService: EventService
    - committeeService: CommitteeService
    + seedInitialData(): void
  }
}

AccountService --> UserRepository

EventService --> SubmissionEventRepository
EventService --> ResettableRepository : limpa dados do evento
EventService --> ReviewWorkflowContext
EventService ..> ReviewWorkflowFactory
EventService --> ArticleRepository
EventService --> ReviewRepository
EventService --> ReviewerRepository

CommitteeService --> UserRepository
CommitteeService --> AreaRepository
CommitteeService --> ReviewerRepository

ArticleReviewService --> ArticleRepository
ArticleReviewService --> ReviewRepository
ArticleReviewService --> CommitteeService
ArticleReviewService --> EventService
ArticleReviewService --> AccountService
ArticleReviewService --> ReviewWorkflowContext
ArticleReviewService --> EventPublisher

DistributionService --> ArticleRepository
DistributionService --> ReviewerRepository
DistributionService --> ReviewRepository
DistributionService --> ReviewWorkflowContext
DistributionService --> EventPublisher

DataSeeder --> AccountService
DataSeeder --> EventService
DataSeeder --> CommitteeService


' ============================================================
' FACADE + PROXY
' ============================================================

package "Facades e Proxy" as FacadePkg {

  interface CoordinatorActions {
    + startEvent(data: StartEventData): SubmissionEvent
    + registerArea(name: String): Area
    + inviteReviewer(userId: Integer): ReviewerProfile
    + distributeArticles(): void
    + getDashboard(): CoordinatorDashboard
  }

  class CoordinatorFacade <<Facade>> {
    - eventService: EventService
    - committeeService: CommitteeService
    - distributionService: DistributionService
    + startEvent(data: StartEventData): SubmissionEvent
    + registerArea(name: String): Area
    + inviteReviewer(userId: Integer): ReviewerProfile
    + distributeArticles(): void
    + getDashboard(): CoordinatorDashboard
  }

  class CoordinatorAuthorizationProxy <<Proxy>> {
    - target: CoordinatorActions
    - accountService: AccountService
    + startEvent(data: StartEventData): SubmissionEvent
    + registerArea(name: String): Area
    + inviteReviewer(userId: Integer): ReviewerProfile
    + distributeArticles(): void
    + getDashboard(): CoordinatorDashboard
    - requireCoordinator(): void
  }

  interface ResearcherActions {
    + submitArticle(data: SubmitArticleData): Article
    + listMyArticles(): List<Article>
    + listAssignedArticles(): List<ArticleForReviewDTO>
    + submitReview(data: ReviewData): void
    + needsExpertiseAreas(): boolean
    + defineExpertiseAreas(data: DefineReviewerAreasData): ReviewerProfile
    + listAvailableAreas(): List<Area>
  }

  class ResearcherFacade <<Facade>> {
    - articleReviewService: ArticleReviewService
    - committeeService: CommitteeService
    - accountService: AccountService
    + submitArticle(data: SubmitArticleData): Article
    + listMyArticles(): List<Article>
    + listAssignedArticles(): List<ArticleForReviewDTO>
    + submitReview(data: ReviewData): void
    + needsExpertiseAreas(): boolean
    + defineExpertiseAreas(data: DefineReviewerAreasData): ReviewerProfile
    + listAvailableAreas(): List<Area>
  }
}

CoordinatorActions <|.. CoordinatorFacade
CoordinatorActions <|.. CoordinatorAuthorizationProxy

CoordinatorAuthorizationProxy o-- CoordinatorActions
CoordinatorAuthorizationProxy --> AccountService
CoordinatorAuthorizationProxy --> UnauthorizedOperationException

CoordinatorFacade --> EventService
CoordinatorFacade --> CommitteeService
CoordinatorFacade --> DistributionService

ResearcherActions <|.. ResearcherFacade

ResearcherFacade --> ArticleReviewService
ResearcherFacade --> CommitteeService
ResearcherFacade --> AccountService


' ============================================================
' APRESENTAÇÃO
' ============================================================

package "Apresentação" as PresentationPkg {

  class LoginFlowController {
    - accountService: AccountService
    - researcherActions: ResearcherActions
    - reviewerAreaSetupScreen: ReviewerAreaSetupScreen
    - mainMenu: MainMenu
    + afterLogin(): void
  }

  class MainMenu {
    - coordinatorMenu: CoordinatorMenu
    - researcherMenu: ResearcherMenu
    + start(): void
  }

  class CoordinatorMenu {
    - inputReader: InputReader
    - consoleView: ConsoleView
    - startEventCommand: StartEventCommand
    - registerAreaCommand: RegisterAreaCommand
    - inviteReviewerCommand: InviteReviewerCommand
    - distributeArticlesCommand: DistributeArticlesCommand
    + show(): void
  }

  class ResearcherMenu {
    - inputReader: InputReader
    - consoleView: ConsoleView
    - submitArticleCommand: SubmitArticleCommand
    - reviewArticleCommand: ReviewArticleCommand
    + show(): void
  }

  class ReviewerAreaSetupScreen {
    - inputReader: InputReader
    - consoleView: ConsoleView
    - researcherActions: ResearcherActions
    - defineReviewerAreasCommand: DefineReviewerAreasCommand
    + show(): void
  }

  class InputReader {
    + readRegisterUserData(): RegisterUserData
    + readStartEventData(): StartEventData
    + readAreaName(): String
    + readReviewerId(): Integer
    + readSubmitArticleData(): SubmitArticleData
    + readReviewData(): ReviewData
    + readReviewerAreasData(areas: List<Area>): DefineReviewerAreasData
  }

  class ConsoleView {
    + showMessage(message: String): void
    + showError(error: Exception): void
    + showAreas(areas: List<Area>): void
    + showDashboard(dashboard: CoordinatorDashboard): void
    + showArticlesForReview(articles: List<ArticleForReviewDTO>): void
  }
}

LoginFlowController --> AccountService
LoginFlowController --> ResearcherActions
LoginFlowController --> ReviewerAreaSetupScreen
LoginFlowController --> MainMenu

MainMenu --> CoordinatorMenu
MainMenu --> ResearcherMenu

CoordinatorMenu --> InputReader
CoordinatorMenu --> ConsoleView

ResearcherMenu --> InputReader
ResearcherMenu --> ConsoleView

ReviewerAreaSetupScreen --> InputReader
ReviewerAreaSetupScreen --> ConsoleView
ReviewerAreaSetupScreen --> ResearcherActions


' ============================================================
' COMMAND
' ============================================================

package "Commands" as CommandPkg {

  interface "Command<T>" as Command <<Command>> {
    + execute(data: T): void
  }

  interface NoDataCommand <<Command>> {
    + execute(): void
  }

  class StartEventCommand {
    - coordinatorActions: CoordinatorActions
    + execute(data: StartEventData): void
  }

  class RegisterAreaCommand {
    - coordinatorActions: CoordinatorActions
    + execute(data: String): void
  }

  class InviteReviewerCommand {
    - coordinatorActions: CoordinatorActions
    + execute(data: Integer): void
  }

  class SubmitArticleCommand {
    - researcherActions: ResearcherActions
    + execute(data: SubmitArticleData): void
  }

  class ReviewArticleCommand {
    - researcherActions: ResearcherActions
    + execute(data: ReviewData): void
  }

  class DefineReviewerAreasCommand {
    - researcherActions: ResearcherActions
    + execute(data: DefineReviewerAreasData): void
  }

  class DistributeArticlesCommand {
    - coordinatorActions: CoordinatorActions
    + execute(): void
  }
}

Command <|.. StartEventCommand
Command <|.. RegisterAreaCommand
Command <|.. InviteReviewerCommand
Command <|.. SubmitArticleCommand
Command <|.. ReviewArticleCommand
Command <|.. DefineReviewerAreasCommand
NoDataCommand <|.. DistributeArticlesCommand

StartEventCommand --> StartEventData
RegisterAreaCommand --> CoordinatorActions
InviteReviewerCommand --> CoordinatorActions
SubmitArticleCommand --> SubmitArticleData
ReviewArticleCommand --> ReviewData
DefineReviewerAreasCommand --> DefineReviewerAreasData

StartEventCommand --> CoordinatorActions
SubmitArticleCommand --> ResearcherActions
ReviewArticleCommand --> ResearcherActions
DefineReviewerAreasCommand --> ResearcherActions
DistributeArticlesCommand --> CoordinatorActions

CoordinatorMenu --> StartEventCommand
CoordinatorMenu --> RegisterAreaCommand
CoordinatorMenu --> InviteReviewerCommand
CoordinatorMenu --> DistributeArticlesCommand

ResearcherMenu --> SubmitArticleCommand
ResearcherMenu --> ReviewArticleCommand

ReviewerAreaSetupScreen --> DefineReviewerAreasCommand


' ============================================================
' RECORDS / DTOs
' ============================================================

package "DTOs / Records" as DtoPkg {

  record RegisterUserData {
    + email: String
    + password: String
    + institution: String
  }

  record StartEventData {
    + name: String
    + city: String
    + submissionDeadline: LocalDate
    + startDate: LocalDate
    + endDate: LocalDate
    + category: Category
    + reviewersPerArticle: int
  }

  record SubmitArticleData {
    + title: String
    + abstractText: String
    + coauthorIds: List<Integer>
    + areaIds: List<Integer>
  }

  record DefineReviewerAreasData {
    + areaIds: List<Integer>
  }

  record ReviewData {
    + reviewId: Integer
    + contribution: String
    + criticism: String
    + verdict: Verdict
  }

  record ArticleForReviewDTO {
    + id: Integer
    + title: String
    + abstractText: String
    + areas: List<String>
  }

  record CoordinatorDashboard {
    + submittedArticles: int
    + reviewers: int
    + evaluatedArticles: int
    + pendingArticles: int
    + pendingDetails: List<PendingArticleInfo>
  }

  record PendingArticleInfo {
    + articleTitle: String
    + reviewerEmail: String
    + dueDate: LocalDate
  }
}

StartEventData --> Category

SubmitArticleData ..> User : coauthorIds
SubmitArticleData ..> Area : areaIds

DefineReviewerAreasData ..> Area : areaIds

ReviewData --> Verdict

ArticleForReviewDTO ..> Article : visão sem autores

CoordinatorDashboard o-- PendingArticleInfo

InputReader ..> RegisterUserData
InputReader ..> StartEventData
InputReader ..> SubmitArticleData
InputReader ..> ReviewData
InputReader ..> DefineReviewerAreasData
InputReader ..> Area

ConsoleView ..> CoordinatorDashboard
ConsoleView ..> Area
ConsoleView ..> ArticleForReviewDTO


' ============================================================
' NOTAS
' ============================================================

note as N1
  Services agrupados por caso de uso:
  - AccountService: cadastro e autenticação
  - EventService: evento atual, reset, dashboard e workflow
  - CommitteeService: áreas temáticas e revisores
  - ArticleReviewService: submissão e avaliação
  - DistributionService: distribuição automática
end note

note as N2
  Commands não leem input.

  A apresentação usa InputReader,
  monta records de entrada e chama
  o command correspondente.
end note

note as N3
  Proxy protege as ações do coordenador.

  Mesmo que a apresentação esconda opções,
  o proxy impede execução indevida.
end note

note as N4
  Repositórios concretos usam listas em memória.

  UserRepository não é resetado.
  Os dados do evento atual são limpos
  por ResettableRepository ao iniciar
  novo evento.
end note

N1 .. ServicePkg
N2 .. CommandPkg
N3 .. CoordinatorAuthorizationProxy
N4 .. RepoPkg

@enduml
