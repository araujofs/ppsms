' COMMAND
' ============================================================

package "Commands" as CommandPkg {

  interface "Command<T>" as Command <<Command>> {
    + execute(data: T): void
  }

  interface NoDataCommand <<Command>> {
    + execute(): void
  }

  class StartEventCommand {
    - coordinatorActions: CoordinatorActions
    + execute(data: StartEventData): void
  }

  class RegisterAreaCommand {
    - coordinatorActions: CoordinatorActions
    + execute(data: String): void
  }

  class InviteReviewerCommand {
    - coordinatorActions: CoordinatorActions
    + execute(data: Integer): void
  }

  class SubmitArticleCommand {
    - researcherActions: ResearcherActions
    + execute(data: SubmitArticleData): void
  }

  class ReviewArticleCommand {
    - researcherActions: ResearcherActions
    + execute(data: ReviewData): void
  }

  class DefineReviewerAreasCommand {
    - researcherActions: ResearcherActions
    + execute(data: DefineReviewerAreasData): void
  }

  class DistributeArticlesCommand {
    - coordinatorActions: CoordinatorActions
    + execute(): void
  }
}

Command <|.. StartEventCommand
Command <|.. RegisterAreaCommand
Command <|.. InviteReviewerCommand
Command <|.. SubmitArticleCommand
Command <|.. ReviewArticleCommand
Command <|.. DefineReviewerAreasCommand
NoDataCommand <|.. DistributeArticlesCommand

StartEventCommand --> StartEventData
RegisterAreaCommand --> CoordinatorActions
InviteReviewerCommand --> CoordinatorActions
SubmitArticleCommand --> SubmitArticleData
ReviewArticleCommand --> ReviewData
DefineReviewerAreasCommand --> DefineReviewerAreasData

StartEventCommand --> CoordinatorActions
SubmitArticleCommand --> ResearcherActions
ReviewArticleCommand --> ResearcherActions
DefineReviewerAreasCommand --> ResearcherActions
DistributeArticlesCommand --> CoordinatorActions

CoordinatorMenu --> StartEventCommand
CoordinatorMenu --> RegisterAreaCommand
CoordinatorMenu --> InviteReviewerCommand
CoordinatorMenu --> DistributeArticlesCommand

ResearcherMenu --> SubmitArticleCommand
ResearcherMenu --> ReviewArticleCommand

ReviewerAreaSetupScreen --> DefineReviewerAreasCommand


' ============================================================
' RECORDS / DTOs
' ============================================================

package "DTOs / Records" as DtoPkg {

  record RegisterUserData {
    + email: String
    + password: String
    + institution: String
  }

  record StartEventData {
    + name: String
    + city: String
    + submissionDeadline: LocalDate
    + startDate: LocalDate
    + endDate: LocalDate
    + category: Category
    + reviewersPerArticle: int
  }

  record SubmitArticleData {
    + title: String
    + abstractText: String
    + coauthorIds: List<Integer>
    + areaIds: List<Integer>
  }

  record DefineReviewerAreasData {
    + areaIds: List<Integer>
  }

  record ReviewData {
    + reviewId: Integer
    + contribution: String
    + criticism: String
    + verdict: Verdict
  }

  record ArticleForReviewDTO {
    + id: Integer
    + title: String
    + abstractText: String
    + areas: List<String>
  }

  record CoordinatorDashboard {
    + submittedArticles: int
    + reviewers: int
    + evaluatedArticles: int
    + pendingArticles: int
    + pendingDetails: List<PendingArticleInfo>
  }

  record PendingArticleInfo {
    + articleTitle: String
    + reviewerEmail: String
    + dueDate: LocalDate
  }
}

StartEventData --> Category

SubmitArticleData ..> User : coauthorIds
SubmitArticleData ..> Area : areaIds

DefineReviewerAreasData ..> Area : areaIds

ReviewData --> Verdict

ArticleForReviewDTO ..> Article : visão sem autores

CoordinatorDashboard o-- PendingArticleInfo

InputReader ..> RegisterUserData
InputReader ..> StartEventData
InputReader ..> SubmitArticleData
InputReader ..> ReviewData
InputReader ..> DefineReviewerAreasData
InputReader ..> Area

ConsoleView ..> CoordinatorDashboard
ConsoleView ..> Area
ConsoleView ..> ArticleForReviewDTO


' ============================================================
' NOTAS
' ============================================================

note as N1
  Services agrupados por caso de uso:
  - AccountService: cadastro e autenticação
  - EventService: evento atual, reset, dashboard e workflow
  - CommitteeService: áreas temáticas e revisores
  - ArticleReviewService: submissão e avaliação
  - DistributionService: distribuição automática
end note

note as N2
  Commands não leem input.

  A apresentação usa InputReader,
  monta records de entrada e chama
  o command correspondente.
end note

note as N3
  Proxy protege as ações do coordenador.

  Mesmo que a apresentação esconda opções,
  o proxy impede execução indevida.
end note

note as N4
  Repositórios concretos usam listas em memória.

  UserRepository não é resetado.
  Os dados do evento atual são limpos
  por ResettableRepository ao iniciar
  novo evento.
end note

N1 .. ServicePkg
N2 .. CommandPkg
N3 .. CoordinatorAuthorizationProxy
N4 .. RepoPkg

@enduml
