@startuml modelo

  enum Category {
    - title: String
  }
  note top: Full Paper,\nShort Paper,\nDemo

  class Area {
    - title: String
    - event: Event
  }

  skinparam packageStyle rectangle
  package Client {}

  package Builder {
    class Event {
      - name: String
      - city: String
      - start: Date
      - end: Date
      - areas: List<Area>
    }

    Event "1, 1" *-- "1, n" Area 
    Event "0, n" *.. "1, 1" Category

    interface EventBuilderInterface {
      + reset()
      + setName(name: String)
      + setCity(city: String)
      + setStart(start: Date)
      + setEnd(end: String)
      + setAreas(areas: List<Area>)
    }


    class EventBuilder implements EventBuilderInterface {
      - result: Event
      + reset()
      + setName(name: String)
      + setCity(city: String)
      + setStart(start: Date)
      + setEnd(end: String)
      + setAreas(areas: List<Area>)
      + getResult(): Event
    }


    class EventBuildingDirector {
      - builder: Builder
      - {static} instance: EventBuildingDirector
      - Director(builder: Builder)
      + {static} getInstance(): EventBuildingDirector
      + changeBuilder(builder: Builder)
      + makeEvent(builder: Builder)
    }


    EventBuilderInterface ..> Area

    EventBuilder --> Event 

    EventBuildingDirector --> EventBuilderInterface
    

    Client --> EventBuildingDirector
    Client ..> EventBuilder
  }

  class EventRepo {
    - {static} instance: EventRepo
    - EventRepo(): EventRepo
    + {static} getInstance(): EventRepo
    + saveEvent(event: Event)
  }

  class EventService {
    - {static} instance: EventService
    - EventService(): EventService
    + {static} getInstance(): EventService
    + startEvent(event: Event)
  }

  EventService ..> Event
  EventRepo ..> Event

  note "Singleton" as N1

  N1 .. EventService
  N1 .. EventRepo
  N1 .. UserService
  N1 .. UserRepo
  N1 .. EventBuildingDirector

  class User { 
    - name: String 
    - email: String
    - password: String
    - institution: String
    - areas: List<Area>
    - roles: List<Role>
  }

  User "0, n" --> "0, n" Area

  class UserRepo {
    - {static} instance: UserRepo
    - UserRepo(): UserRepo
    + {static} getInstance(): UserRepo
    + saveUser(user: User)
  }

  class UserService {
    - {static} instance: UserService
    - UserService(): UserService
    + {static} getInstance(): UserService
    + createUser(user: User)
  }

  UserService ..> User
  UserRepo ..> User


  enum Role {
    - title: String
  }
  note right: RES,\nREV,\nCRD

  User "0, n" *.. "1, n" Role

  class Article {
    - id: Integer
    - title: String
    - abstractText: String
    - file: String
    - authors: List<User>
    - areas: List<Area>
    - reviews: List<Review>
    - status: ArticleState
    + setStatus(status: ArticleState)
    + distribute()
    + addReview(review: Review)
    + finalizeEvaluation()
    + getReviewsForAuthor(): List<Review>
  }

  Article "0, n" --> "1, n" User : authors
  Article "0, n" --> "1, n" Area : areas
  Article "1" *-- "0, n" Review : reviews

  enum Verdict {
    REJECT
    WEAK_REJECT
    WEAK_ACCEPT
    ACCEPT
  }

  class Review {
    - id: Integer
    - contributions: String
    - critiques: String
    - verdict: Verdict
    + Review(contributions: String, critiques: String, verdict: Verdict)
    + getVerdict(): Verdict
    + getContributions(): String
    + getCritiques(): String
  }

  Review "0, n" --> "1" Verdict : verdict
  Review "0, n" --> "1, 1" User : reviewer
  Review "0, n" --> "1, 1" Article : article

  interface ArticleState {
    + distribute(article: Article)
    + addReview(article: Article, review: Review)
    + finalizeEvaluation(article: Article)
    + getReviewsForAuthor(article: Article): List<Review>
  }

  class SubmittedState implements ArticleState {
    + distribute(article: Article)
    + addReview(article: Article, review: Review)
    + finalizeEvaluation(article: Article)
    + getReviewsForAuthor(article: Article): List<Review>
  }

  class UnderReviewState implements ArticleState {
    + distribute(article: Article)
    + addReview(article: Article, review: Review)
    + finalizeEvaluation(article: Article)
    + getReviewsForAuthor(article: Article): List<Review>
  }

  class AcceptedState implements ArticleState {
    + distribute(article: Article)
    + addReview(article: Article, review: Review)
    + finalizeEvaluation(article: Article)
    + getReviewsForAuthor(article: Article): List<Review>
  }

  class RejectedState implements ArticleState {
    + distribute(article: Article)
    + addReview(article: Article, review: Review)
    + finalizeEvaluation(article: Article)
    + getReviewsForAuthor(article: Article): List<Review>
  }

  Article "1" --> "1" ArticleState : status
@enduml